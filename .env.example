# Runtime
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# API and browser access
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]
ENABLE_UPLOADS=false
MAX_UPLOAD_MB=25
MAX_IMPORT_FILES=5
MAX_IMPORT_ROWS=2000000
PROCESSING_CONCURRENCY=1

# SQLite is the zero-configuration default. For PostgreSQL use:
# DATABASE_URL=postgresql+psycopg://playerpulse:playerpulse@localhost:5432/playerpulse
DATABASE_URL=sqlite:///./playerpulse.db

# Local storage and deterministic demo settings
DATA_ROOT=../data
MODEL_ROOT=../models
SYNTHETIC_SEED=20260720

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1

